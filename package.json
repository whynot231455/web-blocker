{
  "name": "web-blocker-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "website",
    "extension",
    "shared"
  ],
  "scripts": {
    "dev:web": "npm run config:extension && npm run dev -w website",
    "build:web": "npm run config:extension && npm run build -w website",
    "lint:web": "npm run lint -w website",
    "config:extension": "node scripts/generate-extension-config.js"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "lightningcss": "^1.32.0",
    "typescript": "^6.0.3"
  }
}
